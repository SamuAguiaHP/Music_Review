generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Tabela de Usuários
model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       String   @default("STANDARD") // Pode ser "STANDARD" ou "ADMIN"
  created_at DateTime @default(now())
  
  reviews    Review[] // Relacionamento: Um usuário pode ter várias avaliações
}

// 2. Tabela de Álbuns
model Album {
  id           String   @id @default(uuid())
  title        String
  artist       String
  release_year Int
  cover_url    String?  // Opcional
  created_at   DateTime @default(now())

  tracks       Track[]  // Um álbum tem várias músicas
  reviews      Review[] // Um álbum pode receber várias avaliações
}

// 3. Tabela de Músicas
model Track {
  id           String   @id @default(uuid())
  title        String
  track_number Int
  
  // Relacionamento com o Álbum
  album_id     String
  album        Album    @relation(fields: [album_id], references: [id], onDelete: Cascade)
  
  reviews      Review[] // Uma música pode receber várias avaliações
}

// 4. Tabela de Avaliações
model Review {
  id         String   @id @default(uuid())
  rating     Int      // Nota de 1 a 5
  comment    String?
  created_at DateTime @default(now())

  // Quem fez a avaliação
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Pode ser uma avaliação de um Álbum...
  album_id   String?
  album      Album?   @relation(fields: [album_id], references: [id], onDelete: Cascade)

  // ...OU uma avaliação de uma Música
  track_id   String?
  track      Track?   @relation(fields: [track_id], references: [id], onDelete: Cascade)
}